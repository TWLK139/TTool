{
  "name": "@ttool/main",
  "version": "0.1.0",
  "description": "TTool Electron 主进程（基座）",
  "author": "TWLK",
  "repository": {
    "type": "git",
    "url": "https://github.com/TWLK139/TTool.git"
  },
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ttool/plugin-types": "workspace:*",
    "@ttool/plugin-notepad": "workspace:*",
    "@ttool/plugin-example": "workspace:*",
    "@ttool/plugin-clipboard-to-table": "workspace:*",
    "@ttool/plugin-ts-to-json": "workspace:*"
  },
  "devDependencies": {
    "electron": "catalog:",
    "electron-builder": "catalog:",
    "typescript": "catalog:"
  },
  "build": {
    "appId": "com.ttool.app",
    "productName": "TTool",
    "npmRebuild": false,
    "icon": "build/icon.png",
    "directories": {
      "output": "../../dist"
    },
    "files": [
      "dist/**/*",
      "build/icon.*"
    ],
    "extraResources": [
      {
        "from": "../renderer/dist",
        "to": "renderer/dist"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
